# Security — never commit API keys
.env

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Virtual environment
venv/
.venv/
env/

# Runtime data files (generated fresh on each run)
data/*.json
!data/fighters_db.json
# Post history must persist on the server — DO NOT ignore
!data/posted_history.json

# Logs
logs/
*.log

# Generated output (images, videos)
output/
visuals/

# Assets cache (auto-downloaded)
assets/images_cache/
assets/backgrounds/
assets/ticket_backgrounds/
assets/background_cache.json

# Temp audio
data/voice_temp.mp3

# Simulation output
simulations/

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
