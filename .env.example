GEMINI_API_KEY=your_gemini_api_key_here

# Optional: UFC moneyline + round totals when Betist/BFO props are empty (https://the-odds-api.com)
THE_ODDS_API_KEY=your_the_odds_api_key_here

# ── Twitter / X (recommended: Pay-per-use on developer.x.com) ─────────────
# 1. developer.x.com → Project → App → User authentication → Read and Write
# 2. Generate Access Token & Secret (OAuth 1.0a) for the bot account
# 3. Billing → add credits (pay-as-you-go: ~$0.01 per tweet posted)
# 4. Paste the four keys below. TWITTER_BACKEND=auto uses API when keys exist.
#
TWITTER_BACKEND=auto
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_SECRET=your_access_token_secret_here

# Fallback only (not recommended on VPS — error 226/344):
# python tools/setup_twitter_cookies.py  →  data/twitter_cookies.json
# TWITTER_BACKEND=cookies

# Pacing for cookie mode only (ignored when official API is active)
# TWITTER_PRE_POST_DELAY_SECONDS=25
# TWITTER_THREAD_DELAY_SECONDS=90
# TWITTER_POST_DELAY_SECONDS=60

# Discord Alerts (Optional but recommended for monitoring)
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here
