# Security — never commit API keys
.env

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Virtual environment
venv/
.venv/
env/

# Runtime data files (generated fresh on each run)
data/*.json
!data/fighters_db.json
# Post history must persist on the server — DO NOT ignore
!data/posted_history.json

# Logs
logs/
*.log

# Generated output (images, videos)
output/
visuals/

# Assets cache (auto-downloaded — but commit fighter portraits for VPS deploy)
# assets/images_cache/   <-- DO NOT ignore: fighter portraits are required on server
assets/backgrounds/
assets/background_cache.json
# ticket_backgrounds/ (bg_safe.png, etc.) — küçük PNG’ler; Versus hafif blend için VPS’te bulunsun (ignore yok)

# Temp audio
data/voice_temp.mp3

# Simulation output
simulations/

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
